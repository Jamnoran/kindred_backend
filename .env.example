# Copy to .env for docker compose; all values have safe local-dev defaults.
DB_NAME=kindred
DB_USER=kindred
DB_PASSWORD=kindred
DB_ROOT_PASSWORD=root

# Object storage (MinIO locally, Cloudflare R2 in prod)
S3_ACCESS_KEY=kindred
S3_SECRET_KEY=kindred-secret
# When running via docker compose, set this to the host-reachable MinIO URL so
# presigned upload URLs work from the browser (not the internal Docker hostname).
# S3_PUBLIC_ENDPOINT=http://localhost:9000

# Frontend base URL — used to build the verification link logged by LoggingVerificationMailer.
# Set to match wherever your web dev server is running (Vite default is 5173).
WEB_BASE_URL=http://localhost:5173

# WebSocket — comma-separated frontend origins allowed for the /ws STOMP handshake.
# Defaults to http://localhost:5173 (Vite dev server). In prod set to your domain.
# WS_ALLOWED_ORIGINS=https://yourdomain.com
