  "components": {
    "schemas": {
      "UpdateProfileRequest": {
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string",
            "maxLength": 100,
            "minLength": 0
          },
          "bio": {
            "type": "string",
            "maxLength": 2000,
            "minLength": 0
          },
          "gender": {
            "type": "string",
            "enum": [
              "woman",
              "man",
              "nonbinary"
            ]
          },
          "lookingFor": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "maxItems": 10,
            "minItems": 0
          },
          "relationshipStyles": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "monogamy",
                "non_monogamy",
                "open",
                "polyamory"
              ]
            },
            "maxItems": 4,
            "minItems": 0
          },
          "interests": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "maxItems": 20,
            "minItems": 0
          }
        },
        "required": [
          "displayName"
        ]
      },
      "InterestResponse": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        },
        "required": [
          "label",
          "slug"
        ]
      },
      "ProfileResponse": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "integer",
            "format": "int64"
          },
          "displayName": {
            "type": "string"
          },
          "bio": {
            "type": "string"
          },
          "gender": {
            "type": "string",
            "enum": [
              "woman",
              "man",
              "nonbinary"
            ]
          },
          "lookingFor": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "relationshipStyles": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "monogamy",
                "non_monogamy",
                "open",
                "polyamory"
              ]
            }
          },
          "interests": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InterestResponse"
            }
          },
          "locationSet": {
            "type": "boolean"
          },
          "locationVisibility": {
            "type": "string",
            "enum": [
              "exact",
              "approximate",
              "hidden"
            ]
          },
          "locationLabel": {
            "type": "string"
          },
          "lastActiveAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "displayName",
          "interests",
          "lastActiveAt",
          "locationSet",
          "locationVisibility",
          "lookingFor",
          "relationshipStyles",
          "userId"
        ]
      },
      "UpdateLocationRequest": {
        "type": "object",
        "properties": {
          "lat": {
            "type": "number",
            "format": "double",
            "maximum": 90,
            "minimum": -90
          },
          "lng": {
            "type": "number",
            "format": "double",
            "maximum": 180,
            "minimum": -180
          },
          "visibility": {
            "type": "string",
            "enum": [
              "exact",
              "approximate",
              "hidden"
            ]
          }
        }
      },
      "UpdatePreferencesRequest": {
        "type": "object",
        "properties": {
          "distanceKm": {
            "type": "integer",
            "format": "int32",
            "maximum": 500,
            "minimum": 1
          },
          "ageMin": {
            "type": "integer",
            "format": "int32",
            "maximum": 120,
            "minimum": 18
          },
